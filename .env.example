# Required - powers the AI agent pipeline and advisor chat
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Required - county-level Census ACS5 stats (median home value, vacancy, income, etc.)
# Get a free key at https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=your_census_api_key_here

# Required - 30-year fixed mortgage rate from FRED
# Get a free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Optional - live AVM/listing data from RentCast (falls back to Census data if unset)
# Get a key at https://www.rentcast.io/api
RENTCAST_API_KEY=
